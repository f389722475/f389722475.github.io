---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../../config";
import { url } from "../../../utils/url-utils";
import Image from "../../atoms/Image/Image.astro";
import TypewriterText from "../../atoms/typewriter-text/TypewriterText.astro";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
---

<div class="card-base p-3">
	<a
		aria-label="前往关于页面"
		href={url("/about/")}
		class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
			aspect-square max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95"
	>
		<div
			class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center"
		>
			<Icon
				name="fa7-regular:address-card"
				class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
			/>
		</div>
		<Image
			src={profileConfig.avatar || ""}
			alt="作者头像"
			class="mx-auto lg:w-full h-full lg:mt-0"
			loading="eager"
			fetchpriority="high"
			widths={[320, 640]}
			sizes="(max-width: 1023px) 12rem, 18rem"
		/>
	</a>
	<div class="px-2">
		<div
			class="profile-name-line font-bold text-xl text-center mb-4 dark:text-neutral-50 transition"
		>
			<span class="profile-name-anchor">
				<span class="profile-name-text">{profileConfig.name}</span>
			</span>
			<span
				class="admin-badge"
				title="站点管理员"
				aria-label="站点管理员"
			>
				<Icon
					name="material-symbols:auto-awesome-rounded"
					class="admin-badge__spark"
					aria-hidden="true"
				/>
				<span>Admin</span>
			</span>
		</div>
		<div class="text-center text-neutral-400 mb-2.5 transition">
			{
				profileConfig.typewriter?.enable ? (
					<TypewriterText
						text={profileConfig.bio || ""}
						speed={profileConfig.typewriter.speed}
						class="inline-block"
					/>
				) : (
					profileConfig.bio
				)
			}
		</div>

		<div class="flex flex-wrap gap-2 justify-center mb-1">
			{
				profileConfig.links.length > 1 &&
					profileConfig.links.map((item) => (
						<a
							rel="me"
							aria-label={item.name}
							href={item.url}
							target="_blank"
							class="btn-regular rounded-lg h-10 w-10 active:scale-90"
						>
							<Icon name={item.icon} class="text-[1.5rem]" />
						</a>
					))
			}
			{
				profileConfig.links.length == 1 && (
					<a
						rel="me"
						aria-label={profileConfig.links[0].name}
						href={profileConfig.links[0].url}
						target="_blank"
						class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
					>
						<Icon
							name={profileConfig.links[0].icon}
							class="text-[1.5rem]"
						/>
						{profileConfig.links[0].name}
					</a>
				)
			}
		</div>

		<div class="umami-stats-container hidden">
			<hr
				class="my-2 border-t border-dashed border-black/10 dark:border-white/10 transition-colors duration-150"
			/>
			<div
				class="text-sm text-50 mt-2 text-center transition-colors duration-150"
			>
				<Icon
					name="fa7-solid:eye"
					class="inline-block mr-1 text-50 text-sm align-middle"
				/>
				<span class="site-stats-display"
					>{i18n(I18nKey.profileStatsLoading)}</span
				>
			</div>
		</div>
	</div>
</div>

<script
	is:inline
	define:vars={{
		profileStatsPageViews: i18n(I18nKey.profileStatsPageViews),
		profileStatsVisits: i18n(I18nKey.profileStatsVisits),
		profileStatsUnavailable: i18n(I18nKey.profileStatsUnavailable),
	}}
>
	function generateStatsText(pageViews, visits) {
		return `${profileStatsPageViews} ${pageViews} · ${profileStatsVisits} ${visits}`;
	}

	async function fetchSiteStats(isRetry = false) {
		const containers = document.querySelectorAll(".umami-stats-container");

		// oddmisc 未加载则等待重试
		if (!window.oddmisc) {
			if (!isRetry) {
				setTimeout(() => fetchSiteStats(true), 500);
			} else {
				containers.forEach((c) => c.classList.add("hidden"));
			}
			return;
		}

		try {
			const stats = await window.oddmisc.getSiteStats();
			const pageViews = stats.pageviews || 0;
			const visits = stats.visits || 0;

			// 数据为 0 时隐藏
			if (pageViews === 0 && visits === 0) {
				containers.forEach((c) => c.classList.add("hidden"));
				return;
			}

			containers.forEach((c) => c.classList.remove("hidden"));
			document.querySelectorAll(".site-stats-display").forEach((el) => {
				el.textContent = generateStatsText(pageViews, visits);
			});
		} catch (error) {
			console.error("Error fetching site stats:", error);
			containers.forEach((c) => c.classList.add("hidden"));
		}
	}

	// 避免多个 Profile 实例重复请求
	if (!window.__siteStatsFetching) {
		window.__siteStatsFetching = true;
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", () =>
				fetchSiteStats(),
			);
		} else {
			fetchSiteStats();
		}
	}
</script>

<style>
	.profile-name-line {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.42rem;
		min-width: 0;
	}

	.profile-name-text {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.profile-name-anchor {
		position: relative;
		display: inline-flex;
		min-width: 0;
	}

	.profile-name-anchor::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.5rem;
		height: 0.25rem;
		border-radius: 9999px;
		background: var(--primary);
	}

	.admin-badge {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		display: inline-flex;
		align-items: center;
		gap: 0.22rem;
		flex: 0 0 auto;
		padding: 0.25rem 0.48rem 0.26rem 0.34rem;
		border-radius: 999px;
		color: #fff;
		font:
			800 0.625rem/1 ui-sans-serif,
			system-ui,
			sans-serif;
		letter-spacing: 0.07em;
		background-color: var(--primary);
		background-image: linear-gradient(
			115deg,
			color-mix(in oklch, var(--primary) 70%, black 30%),
			oklch(0.5 0.2 300),
			color-mix(in oklch, var(--primary) 70%, black 30%)
		);
		background-size: 240% 100%;
		box-shadow:
			0 0 0 1px color-mix(in oklch, var(--primary) 45%, white 55%),
			0 3px 12px color-mix(in oklch, var(--primary) 42%, transparent);
		animation:
			admin-gradient 5s ease-in-out infinite,
			admin-glow 2.6s ease-in-out infinite;
	}

	.admin-badge::before {
		content: "";
		position: absolute;
		inset: -55% auto -55% 0;
		width: 38%;
		pointer-events: none;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.78),
			transparent
		);
		transform: translateX(-190%) skewX(-18deg);
		animation: admin-shine 3.4s ease-in-out infinite;
	}

	.admin-badge > *,
	.admin-badge__spark {
		position: relative;
		z-index: 1;
	}

	.admin-badge__spark {
		width: 0.72rem;
		height: 0.72rem;
		animation: admin-spark 2.6s ease-in-out infinite;
	}

	@keyframes admin-gradient {
		0%,
		100% {
			background-position: 0 50%;
		}
		50% {
			background-position: 100% 50%;
		}
	}

	@keyframes admin-glow {
		0%,
		100% {
			box-shadow:
				0 0 0 1px color-mix(in oklch, var(--primary) 45%, white 55%),
				0 3px 10px color-mix(in oklch, var(--primary) 30%, transparent);
		}
		50% {
			box-shadow:
				0 0 0 1px color-mix(in oklch, var(--primary) 60%, white 40%),
				0 4px 16px color-mix(in oklch, var(--primary) 55%, transparent);
		}
	}

	@keyframes admin-shine {
		0%,
		55% {
			opacity: 0;
			transform: translateX(-190%) skewX(-18deg);
		}
		65% {
			opacity: 0.8;
		}
		88%,
		100% {
			opacity: 0;
			transform: translateX(430%) skewX(-18deg);
		}
	}

	@keyframes admin-spark {
		0%,
		100% {
			transform: rotate(0) scale(1);
		}
		50% {
			transform: rotate(18deg) scale(1.18);
		}
	}

	@media (max-width: 22rem) {
		.profile-name-line {
			gap: 0.3rem;
		}

		.admin-badge {
			font-size: 0.56rem;
			padding-inline: 0.3rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.admin-badge,
		.admin-badge::before,
		.admin-badge__spark {
			animation: none;
		}

		.admin-badge::before {
			display: none;
		}
	}

	@media (prefers-contrast: more) {
		.admin-badge {
			outline: 2px solid var(--primary);
			outline-offset: 2px;
			box-shadow: none;
		}
	}
</style>
